{
  "version": 2,
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/vendas", "destination": "/vendas.html" },
    { "source": "/estoque", "destination": "/estoque.html" },
    { "source": "/contabil", "destination": "/contabil.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/settings", "destination": "/settings.html" },
    { "source": "/onboarding", "destination": "/onboarding.html" },
    { "source": "/anuncios", "destination": "/anuncios.html" },
    { "source": "/compras", "destination": "/compras.html" },
    { "source": "/conciliacao", "destination": "/conciliacao.html" },
    { "source": "/oauth/callback", "destination": "/oauth-callback.html" },
    { "source": "/pedidos",  "destination": "/pedidos.html" },
    { "source": "/landing",  "destination": "/landing.html" },
    { "source": "/home",     "destination": "/landing.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com https://fonts.googleapis.com https://cdn.jsdelivr.net https://unpkg.com https://esm.sh; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: https://ui-avatars.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.stripe.com https://esm.sh;" }
      ]
    }
  ]
}
