# =============================================================================
# E-CONOMIA: Variaveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais
# =============================================================================

# --- Supabase (obrigatorio) ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# URL do frontend (para redirect pos-OAuth)
FRONTEND_URL=https://seu-site.vercel.app

# --- Mercado Livre ---
# Criar app em: https://developers.mercadolivre.com.br/devcenter
ML_APP_ID=123456789
ML_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ML_REDIRECT_URI=https://xxxxx.supabase.co/functions/v1/marketplace-oauth/callback

# --- Nuvemshop ---
# Criar app em: https://partners.nuvemshop.com.br/
NUVEMSHOP_APP_ID=12345
NUVEMSHOP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Amazon SP-API (futuro) ---
# AMAZON_CLIENT_ID=
# AMAZON_CLIENT_SECRET=
# AMAZON_REFRESH_TOKEN=

# --- Shopee Open API (futuro) ---
# SHOPEE_PARTNER_ID=
# SHOPEE_PARTNER_KEY=

# --- NFe / Nota Fiscal (futuro) ---
# FOCUS_NFE_TOKEN=
# FOCUS_NFE_ENVIRONMENT=sandbox
